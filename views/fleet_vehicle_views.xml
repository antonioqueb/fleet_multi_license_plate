<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista formulario: agrupar las tres matrículas -->
    <record id="fleet_vehicle_view_form_multi_plate" model="ir.ui.view">
        <field name="name">fleet.vehicle.form.multi.plate</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="arch" type="xml">
            <field name="license_plate" position="replace">
                <field name="license_plate" string="Matrícula 1" required="1"/>
                <field name="license_plate_2" string="Matrícula 2"/>
                <field name="license_plate_3" string="Matrícula 3"/>
            </field>
        </field>
    </record>

    <!-- Vista lista: columnas opcionales para matrículas 2 y 3 -->
    <record id="fleet_vehicle_view_list_multi_plate" model="ir.ui.view">
        <field name="name">fleet.vehicle.list.multi.plate</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_tree"/>
        <field name="arch" type="xml">
            <field name="license_plate" position="after">
                <field name="license_plate_2" string="Matrícula 2" optional="hide"/>
                <field name="license_plate_3" string="Matrícula 3" optional="hide"/>
            </field>
        </field>
    </record>

    <!-- Filtrar conductores en el formulario de flota -->
    <record id="fleet_vehicle_view_form_driver_filter" model="ir.ui.view">
        <field name="name">fleet.vehicle.form.driver.filter</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="arch" type="xml">
            <field name="driver_id" position="attributes">
                <attribute name="domain">[('is_driver', '=', True)]</attribute>
            </field>
            <field name="future_driver_id" position="attributes">
                <attribute name="domain">[('is_driver', '=', True)]</attribute>
            </field>
        </field>
    </record>

</odoo>